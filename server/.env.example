# =============================================================================
# AI炼金 · 后端环境变量示例（可提交仓库 / 可开源）
# =============================================================================
# 使用方式：
#   1. 复制本文件为同目录下的 .env
#      cp .env.example .env        # Linux / macOS
#      copy .env.example .env      # Windows
#   2. 将下方占位符替换为你的真实配置
#   3. .env 已被 .gitignore 忽略，切勿把密钥提交到 Git
#
# 文档：docs/用户系统与成长体系-方案设计文档.md §8
# =============================================================================

# --- AI（DeepSeek）---
# 获取：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 单次 LLM 调用超时（秒）；出题流程含两次串行调用，建议 ≥60
AI_TIMEOUT_SECONDS=60

# 跨域，本地开发可保持 *
CORS_ORIGINS=*

# --- MySQL ---
# 初始化：npm run db:init（见 server/db/README.md）
DATABASE_URL=mysql+pymysql://root:your-password@127.0.0.1:3306/ai_alchemy?charset=utf8mb4

# 也可使用分项配置（init_database.py 同样支持）
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-password

# --- JWT（用户登录态）---
# 生产环境请使用足够长的随机字符串
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_SECONDS=604800

# --- 微信小程序 ---
# 获取：微信公众平台 → 开发 → 开发管理 → 开发设置
# AppID 需与 frontend/project.config.json 中 appid 一致（或改为你自己的小程序）
WECHAT_APP_ID=wx-your-mini-program-appid
WECHAT_APP_SECRET=your-wechat-app-secret

# 无 AppSecret 时可用 Mock 登录；配置真实密钥后建议设为 false
DEV_MOCK_LOGIN=true

# --- 联网检索（Tavily + Research Agent）---
# 获取：https://tavily.com/
# ⚠️ 真实密钥请写在 server/.env（勿提交 Git），不要写在本 example 文件中
TAVILY_API_KEY=
TAVILY_MOCK=true
RESEARCH_AGENT_MAX_TOOL_CALLS=4
RESEARCH_AGENT_TIMEOUT_SECONDS=45
TAVILY_SEARCH_MAX_RESULTS=8
TAVILY_SEARCH_DEFAULT_DEPTH=advanced
RESEARCH_SESSION_TTL_SECONDS=1800

# 异步 AI 任务 TTL（秒）
GENERATION_TASK_TTL_SECONDS=3600

# 本地存储目录（相对 server/ 工作目录）；对外访问需配置 PUBLIC_BASE_URL
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://127.0.0.1:8000
